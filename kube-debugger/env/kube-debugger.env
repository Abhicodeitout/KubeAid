# KubeAid default environment variables.
# This file is auto-loaded by Make targets (bootstrap/run).
# Edit values here as needed.

# AI provider: ollama | groq
export KUBEAID_AI_PROVIDER=ollama

# Default free local model
export KUBEAID_AI_MODEL=llama3.2

# Ollama local API endpoint
export KUBEAID_OLLAMA_URL=http://localhost:11434

# AI timeout in seconds for larger prompts / slower CPUs
export KUBEAID_AI_TIMEOUT_SECONDS=180

# Optional: default namespace used by analyzer when --namespace is not provided
export KUBE_NAMESPACE=default

# Optional Groq key (leave empty unless using Groq)
# export GROQ_API_KEY=
